{
  "name": "@delega-dev/mcp",
  "version": "1.0.2",
  "mcpName": "io.github.delega-dev/delega",
  "description": "MCP server for Delega \u2014 task infrastructure for AI agents",
  "type": "module",
  "bin": {
    "delega-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
