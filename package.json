{
  "name": "@delega-dev/mcp",
  "version": "1.15.0",
  "mcpName": "io.github.delega-dev/delega",
  "description": "MCP server for Delega — the task handoff layer for AI agents",
  "type": "module",
  "bin": {
    "delega-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublish-check": "bash scripts/prepublish-check.sh",
    "prepublishOnly": "npm run prepublish-check && npm test && npm run build",
    "version": "node scripts/sync-server-version.mjs && git add server.json"
  },
  "keywords": [
    "mcp",
    "delega",
    "tasks",
    "ai-agents",
    "delegation",
    "model-context-protocol",
    "task-management",
    "agent-infrastructure"
  ],
  "author": "Delega Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/delega-dev/delega-mcp"
  },
  "homepage": "https://delega.dev",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "2.0.11",
    "body-parser": "2.3.0",
    "esbuild": "0.28.1",
    "fast-uri": "3.1.4",
    "hono": "4.12.31"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/delega-dev/delega-mcp/issues"
  }
}
